# =====================================================================
# Alpes in Bike : variables d environnement
# =====================================================================
# Copier ce fichier en .env (jamais commit, deja dans .gitignore)
# et remplir avec les vraies cles.

# =====================================================================
# SUPABASE (obligatoire pour que tout fonctionne)
# =====================================================================
# Dashboard > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# =====================================================================
# EXPO (pour les push notifications)
# =====================================================================
# Apres expo init, recuperer le project ID
# Dashboard expo.dev > votre projet > Project ID
EXPO_PUBLIC_EXPO_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =====================================================================
# STRIPE IDENTITY (verification d identite, plus tard)
# =====================================================================
# Dashboard Stripe > API keys
# Utiliser la cle PUBLIQUE en frontend
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# La cle secrete reste cote serveur (Edge function Supabase)

# =====================================================================
# OAUTH PROVIDERS pour montres et capteurs (plus tard)
# =====================================================================
# Strava : https://www.strava.com/settings/api
EXPO_PUBLIC_STRAVA_CLIENT_ID=

# Garmin : https://developer.garmin.com (approval 1 a 2 jours)
EXPO_PUBLIC_GARMIN_CLIENT_ID=

# Whoop : https://developer.whoop.com
EXPO_PUBLIC_WHOOP_CLIENT_ID=

# Oura : https://cloud.ouraring.com/oauth/applications
EXPO_PUBLIC_OURA_CLIENT_ID=

# Polar : https://admin.polaraccesslink.com
EXPO_PUBLIC_POLAR_CLIENT_ID=

# Suunto : https://www.suunto.com/sports/suunto-app/developer-portal
EXPO_PUBLIC_SUUNTO_CLIENT_ID=

# Wahoo : https://cloud.wahooligan.com
EXPO_PUBLIC_WAHOO_CLIENT_ID=

# Ultrahuman : contacter dev@ultrahuman.com
EXPO_PUBLIC_ULTRAHUMAN_CLIENT_ID=

# Fitbit : https://dev.fitbit.com
EXPO_PUBLIC_FITBIT_CLIENT_ID=

# =====================================================================
# NOTES
# =====================================================================
# - Les cles avec prefix EXPO_PUBLIC_ sont bundlees dans l app et donc
#   visibles par les utilisateurs. Ne JAMAIS y mettre de cle secrete.
# - Les vraies cles SECRETES OAuth (client secret) restent cote backend
#   dans Supabase Edge Functions ou Dashboard providers.
# - Pour activer un connecteur, l app demande a son provider l URL
#   de redirect. Pour Alpes in Bike : alpesinbike://auth-callback
#   (deja configure dans app.json sous scheme).
